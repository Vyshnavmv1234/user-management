<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Login</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      height: 100vh;
      margin: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      /* Custom Gradient */
      background: linear-gradient(135deg, #9bd86c, #8aa0c5);
      font-family: 'Arial';
    }

    .login-card {
      width: 380px;
      background: #ffffff;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }

    .login-card h2 {
      font-weight: 700;
      margin-bottom: 20px;
      text-align: center;
    }

    .login-card a {
      text-decoration: none;
      color: #9bd86c;
    }

    .login-card a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>

  <div class="login-card">

    <h2>Welcome Back</h2>

    <form method="post" action="/user/login" id="loginForm">

      <div class="mb-3">
        <label class="form-label">Email Address</label>
        <input id="email" name="email" type="email" class="form-control" placeholder="Enter your email">
      </div>

      <div class="mb-3">
        <label class="form-label">Password</label>
        <input id="password" name="password" type="password" class="form-control" placeholder="Enter your password">
      </div>

      <button class="btn w-100 text-white" style="background:#9bd86c;" type="submit" >Sign In</button>

    </form>

    <div class="text-center mt-3">
      Don't have an account? <a href="/user/signup">Sign up</a> 
    <p class="mt-4" id="error"></p>
    </div> 
    <div class="ms-4">
    {{#if error}}
  <p class="ms-5 mt-3" style="color: red; font-weight: bold;">{{error}}</p>
{{/if}}
</div>
  </div> 

  <script>
document.getElementById("loginForm").addEventListener("submit", function(e) {

  const email = document.getElementById("email").value.trim();
  const pass = document.getElementById("password").value.trim();
  const error = document.getElementById("error");

  // empty field check
  if (!email && !pass) {
    e.preventDefault();
    error.textContent = "Email and password are required";
    error.style.color = "red";
    return;
  }
    if (!email) {
    e.preventDefault();
    error.textContent = "Email required";
    error.style.color = "red";
    return;
  }
    if (!pass) {
    e.preventDefault();
    error.textContent = "Password required";
    error.style.color = "red";
    return;
  }

  // email format check
  if (!email.includes("@")) {
    e.preventDefault();
    error.textContent = "Enter a valid email";
    return;
  }


});
</script>

</body>
</html>
