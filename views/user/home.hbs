<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Dashboard</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      margin: 0;
      min-height: 100vh;
      background: linear-gradient(to bottom, #9bd86c, #c8f7dc);
      font-family: 'Poppins', sans-serif;
      display: flex;
      flex-direction: column;
    }

    /* Navbar */
    .top-bar {
      background: white;
      padding: 15px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    .logout-btn {
      background:  #9bd86c;
      color: white;
      border-radius: 6px;
      padding: 8px 18px;
      font-weight: 500;
    }

    /* Card Styles */
    .dash-card {
      width: 70%;
      background: white;
      padding: 35px;
      margin: 25px auto;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.12);
    }

    /* Avatar Circle */
    .avatar {
      width: 55px;
      height: 55px;
      background: #9bd86c;
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      font-weight: 600;
    }

    footer {
      margin-top: auto;
      background: white;
      text-align: center;
      padding: 12px;
      font-size: 14px;
      color: #333;
    }

    footer a {
      color: #0e8f75;
      text-decoration: none;
    }

    footer a:hover {
      text-decoration: underline;
    }
  </style>

</head>
<body>

  <!-- Top Navigation -->
  <div class="top-bar">
    <h3 class="m-0 fw-bold">User Dashboard</h3>
    <a href="/user/logout"><button  class="logout-btn btn">Log Out</button></a>
  </div>

  <!-- Welcome Card -->
  <div class="dash-card text-center">
    <h2 class="fw-bold">Welcome Back</h2>
    <p class="text-muted">Explore your dashboard and manage your account with ease.</p>
  </div>

  <!-- Profile Card -->
  <div class="dash-card">
    <h4 class="fw-bold mb-3">Your Profile</h4>

    <div class="d-flex align-items-center">
      
      <p class="m-0">Email: {{user.email}} </p>
    </div>
  </div>

  <!-- Footer -->
  <footer>
    © 2025 YourApp. All rights reserved. 
    <a href="#">Privacy Policy</a>
  </footer>

</body>
</html>
