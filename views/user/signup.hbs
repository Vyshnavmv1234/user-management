<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Account</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      margin: 0;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(to bottom,  #9bd86c, #8aa0c5);
      font-family: 'Poppins', sans-serif;
    }

    .signup-card {
      width: 450px;
      background: #fff;
      padding: 40px;
      border-radius: 12px;
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.15);
    }

    .signup-card h2 {
      font-weight: 700;
      text-align: center;
      margin-bottom: 30px;
    }

    .btn-signup {
      background: #9bd86c;
      color: white;
      padding: 10px;
      font-size: 17px;
      border-radius: 6px;
    }

    a {
      text-decoration: none;
      color:  #9bd86c ;
      font-weight: 500;
    }
    a:hover {
      text-decoration: underline;
    }
  </style>

</head>
<body>

  <div class="signup-card">
    <h2>Create an Account</h2>

    <form method="post" action="/user/signup" id="loginForm">

     <div class="mb-3">
        <label class="form-label">Username</label>
        <input id="name" type="name" class="form-control" name="name" placeholder="Enter your name">
      </div>

      <div class="mb-3">
        <label class="form-label">Email Address</label>
        <input id="email" type="email" class="form-control" name="email" placeholder="Enter your email">
      </div>

      <div class="mb-3">
        <label class="form-label">Password</label>
        <input id="password" type="password" name="password" class="form-control" placeholder="Enter your password">
      </div>

      <div class="mb-4">
        <label class="form-label">Confirm Password</label>
        <input id="confirmPass" type="password" name="confirmPassword" class="form-control" placeholder="Confirm your password">
      </div>

      <button class="btn btn-signup w-100">Sign Up</button>

    </form>

    <p class="text-center mt-3">
      Already have an account?
      <a href="/user/login">Sign in</a>
    </p>

    <p class="mt-4 text-center" id="error"></p>

    <div class="ms-5">
     {{#if error}}
  <p class="ms-5" style="color: red; font-weight: bold;">{{error}}</p>
   {{/if}}
    </div>

  </div>

  <script>
document.getElementById("loginForm").addEventListener("submit", function(e) {
  const name = document.getElementById("name").value.trim();
  const email = document.getElementById("email").value.trim();
  const pass = document.getElementById("password").value.trim();
  const cP = document.getElementById("confirmPass").value.trim()
  const error = document.getElementById("error");

  // empty field check
  if (!email && !pass && !name) {
    e.preventDefault();
    error.textContent = "Email username and password are required";
    error.style.color = "red";
    return;
  }
  if (!email && !pass) {
    e.preventDefault();
    error.textContent = "Email1 and password are required";
    error.style.color = "red";
    return;
  }
    if (!email) {
    e.preventDefault();
    error.textContent = "Email required";
    error.style.color = "red";
    return;
  }
  if (!name) {
    e.preventDefault();
    error.textContent = "username required";
    error.style.color = "red";
    return;
  }
    if (!pass) {
    e.preventDefault();
    error.textContent = "Password required";
    error.style.color = "red";
    return;
  }

  // email format check
  if (!email.includes("@")) {
    e.preventDefault();
    error.textContent = "Enter a valid email";
    error.style.color = "red";
    return;
  }
  if(pass != cP){
    e.preventDefault();
    error.textContent = "Password do not match";
    error.style.color = "red";
    return;
  }


});
</script>

</body>
</html>
