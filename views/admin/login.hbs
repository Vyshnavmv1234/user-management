<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      margin: 0;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(to bottom, #9bd86c, #c8f7dc);
      font-family: 'Poppins', sans-serif;
    }

    .admin-card {
      width: 420px;
      background: white;
      padding: 40px;
      border-radius: 12px;
      box-shadow: 0 12px 28px rgba(0,0,0,0.15);
    }

    .admin-card h2 {
      font-weight: 700;
      text-align: center;
      margin-bottom: 25px;
    }

    .btn-login {
      background:  #9bd86c;
      color: white;
      font-size: 17px;
      padding: 10px;
      border-radius: 6px;
      font-weight: 500;
    }
  </style>

</head>
<body>

  <div class="admin-card">

    <h2>Admin Only</h2>

    <form method="post" action="/admin/login" id="loginForm">

      <div class="mb-3">
        <label class="form-label">Email Address</label>
        <input name="email" type="email" class="form-control" placeholder="Enter your email" id="email">
      </div>

      <div class="mb-4">
        <label class="form-label">Password</label>
        <input name="password" type="password" class="form-control" placeholder="Enter your password" id="password">
        
      </div>

      <button class="btn btn-login w-100">Log In</button>
      <p class="text-center mt-3" id="error"></p>
      <div class="ms-5"> 
        {{#if error}}
        <p class="ms-5 mt-3" style="color: red; font-weight: bold;">{{error}}</p>
        {{/if}}
         
        </div>

    </form>

  </div>

    <script>
document.getElementById("loginForm").addEventListener("submit", function(e) {

  const email = document.getElementById("email").value.trim();
  const pass = document.getElementById("password").value.trim();
  const error = document.getElementById("error");

  // empty field check
  if (!email && !pass) {
    e.preventDefault();
    error.textContent = "Email and password are required";
    error.style.color = "red";
    return;
  }
    if (!email) {
    e.preventDefault();
    error.textContent = "      Email required";
    error.style.color = "red";
    return;
  }
    if (!pass) {
    e.preventDefault();
    error.textContent = "Password required";
    error.style.color = "red";
    return;
  }

  // email format check
  if (!email.includes("@")) {
    e.preventDefault();
    error.textContent = "Enter a valid email";
    return;
  }


});
</script>

</body>
</html>
